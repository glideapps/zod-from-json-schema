{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "array",
    "prefixItems": [
        {
            "type": "object",
            "properties": {
                "id": {
                    "type": "number"
                },
                "name": {
                    "type": "string"
                }
            },
            "required": [
                "id",
                "name"
            ]
        },
        {
            "type": "array",
            "items": {
                "type": "string"
            }
        },
        {
            "type": "number",
            "minimum": 0,
            "maximum": 100
        }
    ]
}
